# ==== API BACKEND ====
# URL de ton backend exposé (ngrok en dev, URL de prod en production)
# Exemples :
#   ngrok    : https://xxxx.ngrok-free.app/api
#   LAN      : http://192.168.x.x:3000/api
#   prod     : https://api.fixed.app/api
EXPO_PUBLIC_API_URL=https://CHANGEME.ngrok-free.app/api

# ==== SOCKET.IO ====
# Même hôte que l'API, SANS le préfixe /api
# Exemples :
#   ngrok    : https://xxxx.ngrok-free.app
#   LAN      : http://192.168.x.x:3000
#   prod     : https://api.fixed.app
EXPO_PUBLIC_SOCKET_URL=https://CHANGEME.ngrok-free.app

# ==== GOOGLE MAPS ====
# Activer "Maps SDK for iOS" et "Maps SDK for Android" dans la Google Cloud Console
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=CHANGEME

# ==== GOOGLE OAUTH (Sign in with Google) ====
# Créer des "OAuth client ID" dans Google Cloud Console > Credentials :
#   - WEB        : utilisé pour obtenir l'id_token (audience vérifiée côté backend)
#   - iOS        : type "iOS", Bundle ID = app.thefixed.client
#                  -> ajouter son reverse client ID dans app.json (CFBundleURLSchemes)
#   - ANDROID    : type "Android", package app.thefixed.client + SHA-1 (laisser vide tant que pas de build Android)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=CHANGEME.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=CHANGEME.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# ==== STRIPE ====
# Clé publishable (commence par pk_test_ ou pk_live_)
# Disponible sur https://dashboard.stripe.com/apikeys
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_CHANGEME
