{
  "expo": {
    "name": "FIXED",
    "slug": "fixed-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app-icons-ios/app-icon-1024x1024.png",
    "userInterfaceStyle": "automatic",
    "scheme": [
      "fixed",
      "exp+fixed-app"
    ],
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "image": "./assets/splash-screens/splash-1284x2778.png",
      "resizeMode": "cover",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.thefixed.client",
      "buildNumber": "2",
      "config": {
        "googleMapsApiKey": "AIzaSyCX2pt7Wi5RckO9ur-i4PwSH7XRKdhDe5s"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Votre position permet de trouver les prestataires autour de vous et d'assurer un suivi précis de l'intervention.",
        "NSLocationAlwaysUsageDescription": "Le suivi en arrière-plan permet de vous alerter de l'arrivée de votre prestataire même si l'application est fermée.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Nous utilisons votre position pour garantir la sécurité et la précision du suivi de la mission du début à la fin.",
        "NSMicrophoneUsageDescription": "FIXED utilise votre micro pour les appels vocaux avec votre prestataire ou client."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icons-android/adaptive-icon-foreground.png",
        "backgroundImage": "./assets/app-icons-android/adaptive-icon-background.png"
      },
      "package": "app.thefixed.client",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "fixed",
              "host": "*"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "exp+fixed-app",
              "host": "*"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "FOREGROUND_SERVICE",
        "ACCESS_BACKGROUND_LOCATION",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.fixed.app",
          "enableGooglePay": true
        }
      ],
      "expo-secure-store",
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Autorisez FIXED à suivre l'arrivée de votre prestataire pour une expérience sans attente."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/app-icons-ios/app-icon-1024x1024.png",
          "color": "#000000",
          "sounds": [],
          "iosDisplayInForeground": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "FIXED utilise votre galerie pour ajouter des photos à vos missions et documents.",
          "cameraPermission": "FIXED utilise votre caméra pour prendre des photos lors de vos missions."
        }
      ],
      "expo-localization",
      "expo-web-browser",
      "expo-font",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "thefixedapp",
          "organization": "thefixedapp"
        }
      ],
      "@sentry/react-native"
    ],
    "extra": {
      "apiUrl": "https://api.thefixed.app/api",
      "eas": {
        "projectId": "d6938f3f-e8b0-4b3f-9ddd-d781ef02754a"
      }
    }
  }
}
